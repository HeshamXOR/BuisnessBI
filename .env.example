# ─── LLM Configuration ───────────────────────────
# Available models (fastest → most capable):
#   phi3:mini          — 3.8B, English-only, FAST (default)
#   gemma2:2b          — 2B, ultra-fast
#   llama3.1:8b        — 8B, balanced
#   phi3:medium        — 14B, high quality
#   business-analyst   — Custom fine-tuned (see finetune/README.md)

OLLAMA_MODEL=phi3:mini
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.3

# ─── Data ─────────────────────────────────────────
DATA_DIR=data
